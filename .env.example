# Supabase (yeni ostflow projesi)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — invite link'leri için
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Döviz kuru cron job gizli anahtarı
CRON_SECRET=your-random-secret-here

# Resend (teklif email gönderimleri)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=teklifler@your-domain.com
RESEND_FROM_NAME=Ostflow

# Stripe (abonelik yönetimi)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare R2 (PST/OST arşiv dosyaları ve email ekleri)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=ostflow-archives

# Parser Service (Python FastAPI — PST/OST email parse)
PARSER_SECRET=your-parser-secret
PARSER_SERVICE_URL=https://your-parser-service.com

# Anthropic (ileride AI özellikler için)
ANTHROPIC_API_KEY=sk-ant-...
